# Pinho Law Environment Variables
# Copy to .env.local and fill in real values

# Contact form email service (Resend recommended)
RESEND_API_KEY=

# Public
NEXT_PUBLIC_PHONE=+14070000000
NEXT_PUBLIC_WHATSAPP=14070000000
NEXT_PUBLIC_SITE_URL=https://pinho.law

# Analytics — GA4 Measurement ID (G-XXXXXXXXXX)
# When set, the [locale] layout injects the GA4 tag via @next/third-parties.
# Use the same GA4 property as the internal Pinho dashboard so attribution is unified.
NEXT_PUBLIC_GA_ID=
