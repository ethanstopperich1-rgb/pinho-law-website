# Pinho Law Environment Variables
# Copy to .env.local and fill in real values

# Lead intake — Resend API key powers /api/intake/submit.
# When set: sends firm notification to izi@pinholaw.com + client
# confirmation email. When unset: intake still completes, lead is
# logged to Vercel Function logs, WhatsApp/email fallback CTAs work.
RESEND_API_KEY=
# Optional: override the "from" address (must be verified on Resend).
# Default: notifications@pinho.law
RESEND_FROM_DOMAIN=notifications@pinho.law

# WhatsApp: no env vars — uses wa.me click-to-chat. The intake
# submit API returns a wa.me URL pre-filled with the lead's info;
# the client auto-opens it after the confirmation, so the lead lands
# in the firm's main number (FIRM.whatsapp = +1 (407) 385-4144) with
# one tap.

# Slack lead notifications — Incoming Webhook.
# api.slack.com/apps → Create App → Incoming Webhooks → Add to #leads
# (or whatever channel). Paste the webhook URL here.
# When set, every intake posts a rich message block with quick-action
# buttons (WhatsApp the lead, reply via email, call).
SLACK_WEBHOOK_URL=

# Public
NEXT_PUBLIC_PHONE=+14070000000
NEXT_PUBLIC_WHATSAPP=14070000000
NEXT_PUBLIC_SITE_URL=https://pinho.law

# Analytics — GA4 Measurement ID (G-XXXXXXXXXX)
# When set, the [locale] layout injects the GA4 tag via @next/third-parties.
# Use the same GA4 property as the internal Pinho dashboard so attribution is unified.
NEXT_PUBLIC_GA_ID=

# AI assistant — Anthropic API key for the sitewide chat widget.
# Powers /api/assistant/chat (Claude Haiku 4.5 with navigate_to tool).
# Without this set, the widget shows a graceful WhatsApp-fallback message.
ANTHROPIC_API_KEY=
